{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pip install -r server/requirements.txt && npm run build"
  },
  "deploy": {
    "startCommand": "uvicorn app.main:app --host=0.0.0.0 --port=$PORT --app-dir server",
    "restartPolicyType": "ON_FAILURE"
  }
}
